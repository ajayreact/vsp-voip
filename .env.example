# Core
NODE_ENV=development
PORT=3000
# Local dev (API on host): use localhost
# Docker Compose overrides this in docker-compose.yml with host `postgres`
DATABASE_URL=postgresql://vsp:vsp@localhost:5432/vsp_voip

# Auth & encryption
JWT_SECRET=change-me-in-production
SETTINGS_ENCRYPTION_KEY=32-byte-hex-or-base64-key

# Telnyx
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_MESSAGING_PROFILE_ID=
# WebRTC softphone (Credential Connection) — outbound requires Outbound Voice Profile
TELNYX_CREDENTIAL_CONNECTION_ID=
TELNYX_OUTBOUND_VOICE_PROFILE_ID=
# Inbound PSTN (Call Control Application) — keep phone numbers assigned here
TELNYX_CALL_CONTROL_APP_ID=

# Public URLs (ngrok / production domain)
# Production SaaS:
#   API_PUBLIC_URL=https://api.vspphone.com
#   WEB_ORIGIN=https://app.vspphone.com
#   ADMIN_ORIGIN=https://admin.vspphone.com
# AWS EC2 interim: use the instance public IP or domain — NOT localhost
# Example: API_PUBLIC_URL=http://32.196.41.160:3000
API_PUBLIC_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:3001
ADMIN_ORIGIN=http://localhost:3001

# Redis (required in production)
# Docker Compose overrides this with redis://redis:6379
REDIS_URL=redis://localhost:6379

# Stripe (required in production when billing enabled)
# Dashboard → Developers → Webhooks → signing secret (whsec_...)
# Or: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret_here

# Billing grace periods (days)
BILLING_GRACE_DAYS=7
BILLING_CANCEL_GRACE_DAYS=3

# Webhook verification (default strict in production)
WEBHOOK_STRICT=true

# Email (required in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com
INVOICE_FROM_EMAIL=billing@yourdomain.com

# Logging
LOG_LEVEL=info

# AI platform (Phase 5.1 — disabled by default)
AI_ENABLED=false
AI_PROVIDER=noop
AI_MODEL=gemini-2.5-flash
AI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
LOCAL_LLM_BASE_URL=
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_MS=500
AI_REQUEST_TIMEOUT_MS=60000
AI_FAILOVER_ENABLED=false
AI_FAILOVER_CHAIN=gemini,openai,noop
AI_MESSAGE_SUMMARY_MIN_MESSAGES=10

# Speech-to-Text (Phase 5.3 — disabled by default)
STT_PROVIDER=noop
STT_MODEL=whisper-1
STT_DEFAULT_LANGUAGE=en
GOOGLE_SPEECH_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
LOCAL_WHISPER_BASE_URL=
STT_MAX_RETRIES=2
STT_RETRY_BASE_DELAY_MS=500
STT_REQUEST_TIMEOUT_MS=120000
STT_MAX_AUDIO_BYTES=26214400

# Web portal (Next.js build-time — set on EC2 before deploy/deploy-web.sh)
# Phase 2: browser is admin portal only; mobile app is the telephony client.
NEXT_PUBLIC_BROWSER_CALLING_ENABLED=false
# SOFTPHONE_V2_ENABLED=true enables /softphone-v2 when browser calling is enabled (rollback: false)
SOFTPHONE_V2_ENABLED=true
