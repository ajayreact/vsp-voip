{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "rootDir": "..",
    "baseUrl": ".."
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
