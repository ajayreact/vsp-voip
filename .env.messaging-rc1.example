# Messaging RC1 staging — optional overrides for live Telnyx validation.
# Copy values into .env or export before running:
#   npx tsx scripts/validate-messaging-rc1.js

# Portal login for API tests (defaults match tests/lib/config.ts)
QA_EMAIL=admin@asuitech.com
QA_PASSWORD=Admin@123

# Live Telnyx SMS/MMS — REQUIRED for RC1 outbound tests
# QA_SMS_FROM defaults to first phone number in DB if unset
QA_SMS_FROM=
# External mobile that can receive test SMS/MMS
QA_SMS_TO=

# Public HTTPS URL for outbound MMS media (Telnyx fetches at send time).
# If unset, RC1 uses a local fixture (outbound MMS may SKIP unless API_PUBLIC_URL serves the file).
QA_MMS_MEDIA_URL=
